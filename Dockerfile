# 1. اختيار نسخة بايثون رسمية وخفيفة كقاعدة للمشروع
FROM python:3.9-slim

# 2. تحديد مجلد العمل داخل الحاوية
WORKDIR /app

# 3. نسخ ملف المكتبات المطلوبة إلى الحاوية
COPY requirements.txt .

# 4. تثبيت المكتبات (في حالتنا هي مكتبة Flask)
RUN pip install --no-cache-dir -r requirements.txt

# 5. نسخ كافة ملفات المشروع (app.py والمجلدات الأخرى) إلى الحاوية
COPY . .

# 6. إخبار الحاوية بأن التطبيق سيعمل على المنفذ 5000
EXPOSE 5000

# 7. الأمر النهائي لتشغيل التطبيق بمجرد بدء الحاوية
CMD ["python", "app.py"]
